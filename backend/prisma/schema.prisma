generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Moto {
  id           Int      @id @default(autoincrement())
  marca        String
  modelo       String
  ano          Int?
  cor          String?
  placa        String?
  chassi       String?
  renavam      String?
  dataCompra   DateTime?
  precoCompra  Decimal  @default(0) @db.Decimal(12, 2)
  origemCompra String?
  observacoes       String?
  descricaoModelo   String?  @db.Text
  etiquetaSkuLabel  String?  // Abreviação para etiqueta SKU (ex: "HD ULTRA")
  anexos            Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  pecas             Peca[]
  cadastrosPeca     CadastroPeca[]
}

model Peca {
  id          Int      @id @default(autoincrement())
  idPeca      String   @unique
  motoId      Int
  descricao   String
  localizacao String?
  detranEtiqueta String?
  detranStatus   String?  // 'Inexistente' | 'Sucata' | 'Reutilizavel'
  mercadoLivreItemId String?
  mercadoLivreLink String?
  detranBaixada  Boolean  @default(false)
  detranBaixadaAt DateTime?
  cadastro    DateTime @default(now())
  precoML     Decimal  @default(0) @db.Decimal(12, 2)
  valorLiq    Decimal  @default(0) @db.Decimal(12, 2)
  valorFrete  Decimal  @default(0) @db.Decimal(12, 2)
  valorTaxas  Decimal  @default(0) @db.Decimal(12, 2)
  disponivel  Boolean  @default(true)
  emPrejuizo  Boolean  @default(false)
  dataVenda   DateTime?
  blingPedidoId  String?
  blingPedidoNum String?
  pesoLiquido    Decimal? @db.Decimal(10, 3)
  pesoBruto      Decimal? @db.Decimal(10, 3)
  largura        Decimal? @db.Decimal(10, 2)
  altura         Decimal? @db.Decimal(10, 2)
  profundidade   Decimal? @db.Decimal(10, 2)
  numeroPeca     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  moto        Moto     @relation(fields: [motoId], references: [id])
  prejuizo    Prejuizo?

  @@index([localizacao])
  @@index([mercadoLivreItemId])
  @@index([mercadoLivreLink])
  @@index([motoId, detranEtiqueta])
}

model CadastroPeca {
  id               Int      @id @default(autoincrement())
  motoId           Int
  idPeca           String   @unique
  descricao        String   // titulo (max 60 chars)
  descricaoPeca    String?  @db.Text // corpo do anuncio
  precoVenda       Decimal  @default(0) @db.Decimal(12, 2)
  condicao         String   @default("usado") // usado | novo
  peso             Decimal? @db.Decimal(10, 3)
  largura          Decimal? @db.Decimal(10, 2)
  altura           Decimal? @db.Decimal(10, 2)
  profundidade     Decimal? @db.Decimal(10, 2)
  numeroPeca       String?
  detranEtiqueta   String?
  localizacao      String?
  estoque          Int      @default(1)
  categoriaMLId    String?
  categoriaMLNome  String?
  fotoCapa         String?  // URL ou base64 após upload
  status           String   @default("pre_cadastro") // pre_cadastro | cadastrado
  urlRef           String?  // URL de referência do produto
  blingProdutoId   String?  // ID do produto criado no Bling
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  moto             Moto     @relation(fields: [motoId], references: [id])
}

model Despesa {
  id         Int      @id @default(autoincrement())
  data       DateTime
  detalhes   String
  categoria  String   @default("Outros")
  valor      Decimal  @default(0) @db.Decimal(12, 2)
  importOrigem String?
  importChave String? @unique
  importArquivo String?
  recorrenciaSerieId String?
  recorrenciaTipo String?
  recorrenciaFim DateTime?
  recorrenciaGerada Boolean @default(false)
  statusPagamento String @default("pendente")
  dataPagamento DateTime?
  chavePix   String?
  codigoBarras String?
  observacao String?
  anexoNome  String?
  anexoArquivo String? @db.Text
  comprovanteNome String?
  comprovanteArquivo String? @db.Text
  createdAt  DateTime @default(now())

  @@index([recorrenciaSerieId])
  @@index([recorrenciaTipo])
  @@index([statusPagamento])
  @@index([importOrigem])
  @@index([data])
  @@index([dataPagamento])
}

model Prejuizo {
  id         Int      @id @default(autoincrement())
  data       DateTime
  detalhe    String
  motivo     String?
  observacao String?
  pecaId     Int?     @unique
  valor      Decimal  @default(0) @db.Decimal(12, 2)
  frete      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  peca       Peca?    @relation(fields: [pecaId], references: [id], onDelete: Cascade)
}

model Investimento {
  id        Int      @id @default(autoincrement())
  data      DateTime
  socio     String
  tipo      String   @default("Aporte geral")
  moto      String?
  valor     Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
}

model BlingConfig {
  id                          Int      @id @default(autoincrement())
  clientId                    String   @default("")
  clientSecret                String   @default("")
  accessToken                 String   @default("")
  refreshToken                String   @default("")
  connectedAt                 DateTime?
  prefixos                    Json     @default("[]")
  fretePadrao                 Decimal  @default(29.90) @db.Decimal(12, 2)
  taxaPadraoPct               Decimal  @default(17.00) @db.Decimal(5, 2)
  auditoriaAtiva              Boolean  @default(false)
  auditoriaHorario            String   @default("03:00")
  auditoriaEscopo             String   @default("full")
  auditoriaEmailDestinatario  String   @default("")
  auditoriaResendApiKey       String   @default("")
  auditoriaResendFrom         String   @default("alertas@mail.anbparts.com.br")
  auditoriaTamanhoLote        Int      @default(100)
  auditoriaPausaMs            Int      @default(400)
  consultaManualTamanhoLote   Int      @default(100)
  consultaManualPausaMs       Int      @default(400)
  auditoriaUltimaExecucaoChave String?
  auditoriaUltimaExecucaoEm   DateTime?
  auditoriaLinkMlAtiva        Boolean  @default(false)
  auditoriaLinkMlHorario      String   @default("05:00")
  auditoriaLinkMlIntervaloDias Int     @default(1)
  auditoriaLinkMlUltimaExecucaoChave String?
  auditoriaLinkMlUltimaExecucaoEm DateTime?
  nuvemshopAtiva   Boolean @default(false)
  nuvemshopLojaId  Int     @default(205449158)
  exibirBuscarProdutos Boolean @default(true)
  exibirCompararCSV    Boolean @default(true)
  updatedAt                   DateTime @default(now()) @updatedAt
}

model AuditoriaAutomaticaExecucao {
  id                 Int      @id @default(autoincrement())
  origem             String   @default("manual")
  status             String   @default("pendente")
  startedAt          DateTime @default(now())
  finishedAt         DateTime?
  totalSkus          Int      @default(0)
  totalDivergencias  Int      @default(0)
  totalSemDivergencia Int     @default(0)
  emailDestinatario  String?
  emailEnviado       Boolean  @default(false)
  emailAssunto       String?
  emailErro          String?
  erro               String?
  resumo             Json?
  divergencias       Json?
}

model ConfiguracaoGeral {
  id                        Int      @id @default(autoincrement())
  resendApiKey              String   @default("")
  emailRemetente            String   @default("alertas@mail.anbparts.com.br")
  auditoriaEmailDestinatario String  @default("")
  auditoriaEmailTitulo      String   @default("ALERTA ANB Parts - Divergência de Produtos / Anúncios - Verifique")
  detranEmailDestinatario   String   @default("")
  detranEmailTitulo         String   @default("ALERTA ANB Parts - Baixa de Etiqueta DETRAN - Verifique")
  despesasEmailAtivo        Boolean  @default(false)
  despesasEmailHorario      String   @default("07:00")
  despesasEmailDestinatario String   @default("")
  despesasEmailTitulo       String   @default("ALERTA ANB Parts - Despesas do Dia - Verifique")
  despesasEmailUltimaExecucaoChave String?
  despesasEmailUltimaExecucaoEm DateTime?
  mercadoLivrePerguntasAtivo Boolean @default(false)
  mercadoLivrePerguntasIntervaloMin Int @default(5)
  mercadoLivrePerguntasEmailDestinatario String @default("")
  mercadoLivrePerguntasEmailTitulo String @default("ALERTA ANB Parts - Perguntas Mercado Livre - Verifique")
  mercadoLivrePerguntasUltimaLeituraEm DateTime?
  empresaRazaoSocial        String   @default("")
  empresaCnpj               String   @default("")
  empresaEnderecoCompleto   String   @default("")
  empresaTelefoneWhats      String   @default("")
  empresaAnexos             Json     @default("{}")
  nuvemshopAppId            String   @default("")
  nuvemshopClientSecret     String   @default("")
  nuvemshopAccessToken      String   @default("")
  nuvemshopStoreId          String   @default("")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model MercadoLivreConfig {
  id           Int      @id @default(autoincrement())
  clientId     String   @default("")
  clientSecret String   @default("")
  accessToken  String   @default("")
  refreshToken String   @default("")
  connectedAt  DateTime?
  sellerId     String   @default("")
  nickname     String   @default("")
  siteId       String   @default("MLB")
  mercadoPagoClientId String @default("")
  mercadoPagoClientSecret String @default("")
  mercadoPagoAccessToken String @default("")
  mercadoPagoRefreshToken String @default("")
  mercadoPagoConnectedAt DateTime?
  mercadoPagoUserId String @default("")
  mercadoPagoSaldoAutoAtivo Boolean @default(false)
  mercadoPagoSaldoAutoHorario String @default("06:00")
  mercadoPagoSaldoAutoUltimaExecucaoChave String?
  mercadoPagoSaldoAutoUltimaExecucaoEm DateTime?
  updatedAt    DateTime @updatedAt
}

model MercadoLivrePergunta {
  id               Int      @id @default(autoincrement())
  questionId       String   @unique
  itemId           String?
  status           String   @default("UNANSWERED")
  texto            String   @db.Text
  respostaTexto    String?  @db.Text
  dataPergunta     DateTime?
  respondidaEm     DateTime?
  clienteId        String?
  nomeCliente      String?
  sku              String?
  idPeca           String?
  pecaId           Int?
  descricao        String?
  tituloAnuncio    String?
  linkAnuncio      String?
  raw              Json     @default("{}")
  notificadaEm     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([dataPergunta])
  @@index([notificadaEm])
  @@index([sku])
  @@index([idPeca])
}

model Inventario {
  id         Int      @id @default(autoincrement())
  status     String   @default("em_andamento")
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  caixas     InventarioCaixa[]
  itens      InventarioItem[]

  @@index([status])
  @@index([startedAt])
  @@index([finishedAt])
}

model InventarioCaixa {
  id           Int      @id @default(autoincrement())
  inventarioId Int
  caixa        String
  status       String   @default("pendente")
  finishedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventario   Inventario @relation(fields: [inventarioId], references: [id], onDelete: Cascade)

  @@unique([inventarioId, caixa])
  @@index([caixa])
  @@index([status])
}

model InventarioItem {
  id                Int      @id @default(autoincrement())
  inventarioId      Int
  caixa             String
  skuBase           String
  motoId            Int?
  idPecaReferencia  String?
  descricao         String
  quantidadeEstoque Int      @default(0)
  status            String   @default("pendente")
  tipoDiferenca     String?
  decidedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  inventario        Inventario @relation(fields: [inventarioId], references: [id], onDelete: Cascade)

  @@unique([inventarioId, caixa, skuBase])
  @@index([inventarioId, caixa, status])
  @@index([status])
  @@index([tipoDiferenca])
}
